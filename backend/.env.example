# Database (never commit real credentials)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# Telegram
BOT_TOKEN=replace-with-botfather-token
ADMIN_CHAT_ID=replace-with-telegram-chat-id

# Admin auth
# Generate with: npm run admin:hash -- "your-strong-password"
ADMIN_PASSWORD_HASH=
# Generate with: openssl rand -base64 48
ADMIN_SESSION_SECRET=

# Supabase server-side upload (service role must never be exposed to frontend)
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE=

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
